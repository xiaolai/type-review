# Netlify / Cloudflare Pages headers for the production deploy.
# Vite copies the contents of `public/` to the root of `dist/` at build time,
# so this file lands as `dist/_headers` automatically.
# For Vercel, the same policy needs to be expressed in `vercel.json`.
#
# CSP notes:
#   script-src 'self' static.cloudflareinsights.com
#     — second host is CF Pages' auto-injected Web Analytics beacon.
#       To drop it: disable Web Analytics in the CF dashboard and remove the
#       host from script-src + the matching cloudflareinsights.com in connect-src.
#   style-src 'self' 'unsafe-inline'
#     — Solid components set per-element styles via `style={{...}}` for
#       dynamic values (bar widths, heatmap intensity, calendar coloring).
#       Even setting CSS custom properties is an inline-style attribute,
#       which CSP blocks without 'unsafe-inline'. Inline scripts stay
#       locked — script-src does NOT include 'unsafe-inline'.

/*
  Content-Security-Policy: default-src 'none'; script-src 'self' static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' cloudflareinsights.com; base-uri 'self'; form-action 'none'; frame-ancestors 'none'; object-src 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin
  X-Frame-Options: DENY
