# Netlify / Cloudflare Pages headers for the production deploy.
# Vite copies the contents of `public/` to the root of `dist/` at build time,
# so this file lands as `dist/_headers` automatically.
# For Vercel, the same policy needs to be expressed in `vercel.json`.

/*
  Content-Security-Policy: default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'; object-src 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin
  X-Frame-Options: DENY
